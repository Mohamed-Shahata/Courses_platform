model Lesson {
  id    String @id @default(uuid())
  title String

  videoUrl String
  videoPublicId String

  status LessonStatus @default(PENDING)

  order      Int      
  createdAt  DateTime @default(now())

  quiz      Quiz?

  lessonProgresses LessonProgress[]

  sectionId  String
  section Section @relation(fields: [sectionId], references: [id])
}